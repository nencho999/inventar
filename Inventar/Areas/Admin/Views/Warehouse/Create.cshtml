@model Inventar.Web.ViewModels.Warehouse.WarehouseFormViewModel
@using Inventar.Data.Models
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Add Warehouse"];
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-primary text-white p-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-industry me-2"></i> @Localizer["Add Warehouse"]</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Name" class="form-label fw-bold">@Localizer["Name"]</label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-bold">@Localizer["Location"]</label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-bold">@Localizer["Status"]</label>
                                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<WarehouseStatus>()"></select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-bold">@Localizer["Total Capacity"]</label>
                                <input asp-for="Capacity" class="form-control" placeholder="@Localizer["e.g. 500 units"]" />
                            </div>
                        </div>

                        <h4 class="mt-4 border-bottom pb-2">@Localizer["Select Products & Initial Stock"]</h4>

                        <div class="table-responsive mt-3">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;"></th>
                                        <th>@Localizer["Product Name"]</th>
                                        <th style="width: 200px;">@Localizer["Initial Quantity"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Products.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <input type="hidden" asp-for="Products[i].ProductId" />
                                                <input type="hidden" asp-for="Products[i].ProductName" />
                                                <input type="checkbox" asp-for="Products[i].IsSelected" class="form-check-input" />
                                            </td>
                                            <td>
                                                <label class="form-check-label" asp-for="Products[i].IsSelected">@Model.Products[i].ProductName</label>
                                            </td>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <input asp-for="Products[i].Quantity" class="form-control" type="number" step="0.01" value="0" />
                                                    <span class="input-group-text">pcs/kg</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mb-4 mt-3">
                            <label asp-for="ContactInfo" class="form-label fw-bold">@Localizer["Contact Info"]</label>
                            <textarea asp-for="ContactInfo" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold p-2">@Localizer["Create Warehouse"]</button>
                            <a asp-action="Index" class="btn btn-light border">@Localizer["Cancel"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>