@model Inventar.Web.ViewModels.Warehouse.WarehouseFormViewModel
@using Inventar.Data.Models
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Edit Warehouse"];
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-warning text-dark p-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-edit me-2"></i> @Localizer["Edit Warehouse"]</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">@Localizer["Warehouse Name"]</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Location" class="form-label fw-bold">@Localizer["Location / Address"]</label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-bold">@Localizer["Status"]</label>
                                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<WarehouseStatus>()"></select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Capacity" class="form-label fw-bold">@Localizer["Total Capacity"]</label>
                                <input asp-for="Capacity" class="form-control" />
                            </div>
                        </div>

                        <h4 class="mt-4 border-bottom pb-2">@Localizer["Warehouse Inventory"]</h4>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;"></th>
                                        <th>@Localizer["Product"]</th>
                                        <th style="width: 200px;">@Localizer["Current Stock"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Products.Count; i++)
                                    {
                                        <tr class="@(Model.Products[i].IsSelected ? "table-info" : "")">
                                            <td>
                                                <input type="hidden" asp-for="Products[i].ProductId" />
                                                <input type="hidden" asp-for="Products[i].ProductName" />
                                                <input type="checkbox" asp-for="Products[i].IsSelected" class="form-check-input product-check" />
                                            </td>
                                            <td>
                                                <label class="form-check-label fw-bold">@Model.Products[i].ProductName</label>
                                            </td>
                                            <td>
                                                <input asp-for="Products[i].Quantity" class="form-control form-control-sm text-end" type="number" step="0.01" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mb-4 mt-3">
                            <label asp-for="ContactInfo" class="form-label fw-bold">@Localizer["Contact Information"]</label>
                            <textarea asp-for="ContactInfo" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm">@Localizer["Save Changes"]</button>
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">@Localizer["Cancel"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelectorAll('.product-check').forEach(check => {
            check.addEventListener('change', function() {
                this.closest('tr').classList.toggle('table-info', this.checked);
            });
        });
    </script>
}