@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Production Management"];
}

<div class="container-fluid py-4 text-dark">
    @* --- HEADER SECTION --- *@
    <div class="d-flex align-items-center mb-5 p-4 bg-white rounded shadow-sm border-start border-primary border-5">
        <div class="icon-box bg-primary text-white rounded-3 p-3 me-3 shadow">
            <i class="fas fa-industry fa-2x"></i>
        </div>
        <div>
            <h2 class="h3 mb-0 fw-bold">@Localizer["Production Management"]</h2>
            <p class="text-muted mb-0 small text-uppercase fw-semibold">@Localizer["Manage manufacturing, stock levels, and logistics"]</p>
        </div>
    </div>

    @* --- MAIN OPERATIONS (PRIMARY) --- *@
    <div class="mb-5">
        <h5 class="text-uppercase text-muted small fw-bold mb-3 d-flex align-items-center">
            <span class="me-2 text-primary">@Localizer["Core Operations"]</span>
            <div class="flex-grow-1 border-bottom opacity-25"></div>
        </h5>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <a asp-action="Registration" class="text-decoration-none group-card">
                    <div class="card h-100 border-0 shadow-sm bg-primary text-white overflow-hidden position-relative">
                        <div class="card-body p-4 position-relative" style="z-index: 2;">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <i class="fas fa-plus-circle fa-3x opacity-75"></i>
                                <i class="fas fa-arrow-right opacity-50"></i>
                            </div>
                            <h5 class="fw-bold mb-1">@Localizer["Production Registration"]</h5>
                            <p class="small mb-0 opacity-75">@Localizer["Record newly produced quantities into center stock"]</p>
                        </div>
                        @* Декоративна икона на заден план *@
                        <i class="fas fa-tools position-absolute end-0 bottom-0 mb-n3 me-n2 opacity-25 fa-6x" style="transform: rotate(-15deg);"></i>
                    </div>
                </a>
            </div>
        </div>
    </div>

    @* --- LOGISTICS & TRANSFERS --- *@
    <div class="mb-5">
        <h5 class="text-uppercase text-muted small fw-bold mb-3 d-flex align-items-center">
            <span class="me-2 text-primary">@Localizer["Logistics & Internal Transfers"]</span>
            <div class="flex-grow-1 border-bottom opacity-25"></div>
        </h5>
        <div class="row g-4">
            @* КАРТА 1: ПРЕМЕСТВАНЕ КЪМ СКЛАД (АКТИВНА) *@
            <div class="col-md-4">
                <a asp-controller="Logistics" asp-action="CenterToWarehouse" class="text-decoration-none hover-lift d-block h-100">
                    <div class="card h-100 border-0 shadow-sm border-bottom border-primary border-3">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-primary-subtle text-primary me-3 shadow-sm">
                                <i class="fas fa-truck-moving"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">@Localizer["Center to Warehouse"]</h6>
                                <small class="text-muted">@Localizer["Move stock to central storage"]</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            @* КАРТА 2: ПРЕМЕСТВАНЕ КЪМ ТЪРГОВСКИ ОБЕКТ (Center to Sales Point) *@
            <div class="col-md-4">
                <a asp-controller="Logistics" asp-action="CenterToSalesPoint" class="text-decoration-none hover-lift d-block h-100">
                    <div class="card h-100 border-0 shadow-sm border-bottom border-success border-3">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-success-subtle text-success me-3 shadow-sm">
                                <i class="fas fa-store"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">@Localizer["Center to Sales Point"]</h6>
                                <small class="text-muted">@Localizer["Direct shipment to retail"]</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            @* КАРТА 3: ТРАНСФЕР МЕЖДУ СКЛАДОВЕ *@
            <div class="col-md-4">
                <a asp-controller="Logistics" asp-action="WarehouseTransfer" class="text-decoration-none hover-lift d-block h-100">
                    <div class="card h-100 border-0 shadow-sm border-bottom border-primary border-3">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-primary-subtle text-primary me-3 shadow-sm">
                                <i class="fas fa-exchange-alt"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">@Localizer["Warehouse to Warehouse"]</h6>
                                <small class="text-muted">@Localizer["Between storage locations"]</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Logistics" asp-action="WarehouseToSalesPoint" class="text-decoration-none hover-lift d-block h-100">
                    <div class="card h-100 border-0 shadow-sm border-bottom border-primary border-3">
                        <div class="card-body d-flex align-items-center p-4">
                            <div class="icon-circle bg-primary-subtle text-primary me-3 shadow-sm">
                                <i class="fas fa-exchange-alt"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">@Localizer["Warehouse to Sales Point"]</h6>
                                <small class="text-muted">@Localizer["Between storage locations"]</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>

    @* --- RETURNS & RECLAMATIONS --- *@
    <div class="mb-5">
        <h5 class="text-uppercase text-muted small fw-bold mb-3 d-flex align-items-center">
            <span class="me-2 text-danger">@Localizer["Returns & Quality Control"]</span>
            <div class="flex-grow-1 border-bottom opacity-25 border-danger"></div>
        </h5>
        <div class="row g-4">
            <div class="col-md-6">
                <a href="#" class="text-decoration-none hover-lift d-block">
                    <div class="card border-0 shadow-sm bg-white border-start border-danger border-4">
                        <div class="card-body d-flex justify-content-between align-items-center p-3">
                            <div class="d-flex align-items-center">
                                <div class="p-2 bg-danger-subtle text-danger rounded me-3 shadow-sm">
                                    <i class="fas fa-undo-alt"></i>
                                </div>
                                <span class="fw-bold">@Localizer["Sales Point Return"]</span>
                            </div>
                            <i class="fas fa-chevron-right text-muted px-2"></i>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a href="#" class="text-decoration-none hover-lift d-block">
                    <div class="card border-0 shadow-sm bg-white border-start border-danger border-4">
                        <div class="card-body d-flex justify-content-between align-items-center p-3">
                            <div class="d-flex align-items-center">
                                <div class="p-2 bg-danger-subtle text-danger rounded me-3 shadow-sm">
                                    <i class="fas fa-house-damage"></i>
                                </div>
                                <span class="fw-bold">@Localizer["Warehouse Return to Center"]</span>
                            </div>
                            <i class="fas fa-chevron-right text-muted px-2"></i>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Модерни ефекти за картите */
    .hover-lift {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
    }

        .hover-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.12) !important;
        }

    /* Икони в кръгчета */
    .icon-circle {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    /* Анимация за главната карта */
    .group-card .card {
        transition: all 0.3s ease;
    }

    .group-card:hover .card {
        transform: scale(1.03);
        background: linear-gradient(135deg, #0d6efd 0%, #0056b3 100%) !important;
    }

    /* Системни цветове (Bootstrap 5 Utilities) */
    .bg-primary-subtle {
        background-color: #e7f1ff;
    }

    .bg-danger-subtle {
        background-color: #f8d7da;
    }

    .border-primary-subtle {
        border-color: #cfe2ff !important;
    }
</style>