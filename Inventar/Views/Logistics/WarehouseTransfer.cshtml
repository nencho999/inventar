@model WarehouseTransferViewModel
@using Inventar.Web.ViewModels.Logistics
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-primary fw-bold">
            <i class="fas fa-exchange-alt me-2"></i> @Localizer["Warehouse Transfer"]
        </h2>
        <a asp-action="Index" asp-controller="Production" class="btn btn-outline-secondary shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> @Localizer["Back"]
        </a>
    </div>

    <form asp-action="WarehouseTransfer" method="post" id="transferForm">
        <div class="row g-4">
            <div class="col-lg-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="row">
                            <div class="col-md-5">
                                <label asp-for="FromWarehouseId" class="form-label fw-bold">@Localizer["From Warehouse (Source)"]</label>
                                <select asp-for="FromWarehouseId" class="form-select border-primary-subtle"
                                        asp-items="Model.Warehouses" id="fromWarehouse">
                                    <option value="">-- @Localizer["Select Warehouse"] --</option>
                                </select>
                                <span asp-validation-for="FromWarehouseId" class="text-danger"></span>
                            </div>
                            <div class="col-md-2 d-flex align-items-end justify-content-center pb-2">
                                <i class="fas fa-long-arrow-alt-right fa-2x text-muted d-none d-md-block"></i>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="ToWarehouseId" class="form-label fw-bold">@Localizer["To Warehouse (Destination)"]</label>
                                <select asp-for="ToWarehouseId" class="form-select border-success-subtle"
                                        asp-items="Model.Warehouses" id="toWarehouse">
                                    <option value="">-- @Localizer["Select Warehouse"] --</option>
                                </select>
                                <span asp-validation-for="ToWarehouseId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0 fs-6 text-uppercase fw-bold">
                            <i class="fas fa-boxes me-2"></i> @Localizer["Available Products in Selected Warehouse"]
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px;">
                            <table class="table table-hover align-middle mb-0" id="productsTable">
                                <thead class="bg-light sticky-top">
                                    <tr>
                                        <th>@Localizer["Product"]</th>
                                        <th class="text-center">@Localizer["Current Stock"]</th>
                                        <th style="width: 250px;">@Localizer["Transfer Quantity"]</th>
                                    </tr>
                                </thead>
                                <tbody id="productsTableBody">
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <i class="fas fa-info-circle me-1"></i>
                                            @Localizer["Please select a source warehouse to see availability."]
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="fixed-bottom bg-white border-top py-3 shadow-lg" style="z-index: 1000; margin-left: 250px;">
            <div class="container-fluid px-4 text-end">
                <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                    <i class="fas fa-check-circle me-2"></i> @Localizer["Confirm Transfer"]
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#fromWarehouse').change(function () {
                const warehouseId = $(this).val();
                const $tableBody = $('#productsTableBody');

                if (!warehouseId) {
                    $tableBody.html('<tr><td colspan="3" class="text-center py-5">@Localizer["Select Warehouse"]</td></tr>');
                    return;
                }

                $tableBody.html('<tr><td colspan="3" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>');

                $.getJSON('@Url.Action("GetStocks", "Logistics")', { warehouseId: warehouseId }, function (data) {
                    $tableBody.empty();
                    if (data.length === 0) {
                        $tableBody.html('<tr><td colspan="3" class="text-center py-5 text-warning">@Localizer["No products available in this warehouse."]</td></tr>');
                        return;
                    }

                    $.each(data, function (i, item) {
                        $tableBody.append(`
                            <tr>
                                <td>
                                    <input type="hidden" name="Products[${i}].ProductId" value="${item.productId}" />
                                    <input type="hidden" name="Products[${i}].ProductName" value="${item.productName}" />
                                    <span class="fw-bold text-dark">${item.productName}</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary px-3 py-2">${item.availableQuantity.toFixed(2)}</span>
                                    <input type="hidden" name="Products[${i}].AvailableQuantity" value="${item.availableQuantity}" />
                                </td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="Products[${i}].TransferQuantity"
                                               class="form-control text-center fw-bold"
                                               min="0" max="${item.availableQuantity}" step="0.01" value="0" />
                                        <span class="input-group-text">kg/pcs</span>
                                    </div>
                                </td>
                            </tr>
                        `);
                    });
                });
            });

            $('#transferForm').submit(function (e) {
                const from = $('#fromWarehouse').val();
                const to = $('#toWarehouse').val();
                if (from === to && from !== "") {
                    alert("@Localizer["Source and destination warehouses cannot be the same!"]");
                    e.preventDefault();
                }
            });
        });
    </script>
}