@using Inventar.Web.ViewModels.Production
@using Microsoft.AspNetCore.Mvc.Localization
@model CenterToSalesPointFormModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Center to Sales Point Transfer";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-lg border-0 mt-4">
            <div class="card-header bg-success text-white py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="fas fa-store me-2"></i> @Localizer["Transfer to Sales Point"]
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="CenterToSalesPoint" asp-controller="Logistics" method="post" id="transferForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        @* 1. FROM CENTER *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">@Localizer["From Production Center"]</label>
                            <select asp-for="FromProductionCenterId" id="centerSelect" class="form-select shadow-sm"
                                    asp-items="@(new SelectList(Model.ProductionCenters, "Id", "Name"))">
                                <option value="">-- @Localizer["Select Center"] --</option>
                            </select>
                            <span asp-validation-for="FromProductionCenterId" class="text-danger small"></span>
                        </div>

                        @* 2. TO SALES POINT *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">@Localizer["To Sales Point"]</label>
                            <select asp-for="ToSalesPointId" class="form-select shadow-sm"
                                    asp-items="@(new SelectList(Model.SalesPoints, "Id", "Name"))">
                                <option value="">-- @Localizer["Select Sales Point"] --</option>
                            </select>
                            <span asp-validation-for="ToSalesPointId" class="text-danger small"></span>
                        </div>
                    </div>

                    @* 3. PRODUCT *@
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">@Localizer["Product for Shipment"]</label>
                        <select asp-for="ProductId" id="productSelect" class="form-select shadow-sm" disabled>
                            <option value="">-- @Localizer["Select center first"] --</option>
                        </select>
                        <span asp-validation-for="ProductId" class="text-danger small"></span>
                    </div>

                    @* 4. QUANTITY *@
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">@Localizer["Quantity"]</label>
                        <div class="input-group shadow-sm">
                            <input asp-for="Quantity" type="number" step="0.01" class="form-control" id="quantityInput" placeholder="0.00" />
                            <span class="input-group-text bg-light text-success fw-bold">QTY</span>
                        </div>
                        <span asp-validation-for="Quantity" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-controller="Production" asp-action="Index" class="btn btn-outline-secondary px-4">
                            @Localizer["Cancel"]
                        </a>
                        <button type="submit" class="btn btn-success px-5 fw-bold shadow">
                            <i class="fas fa-truck me-2"></i> @Localizer["Ship to Store"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('centerSelect').addEventListener('change', async function() {
            const centerId = this.value;
            const productSelect = document.getElementById('productSelect');

            productSelect.innerHTML = '<option value="">-- @Localizer["Loading..."] --</option>';
            productSelect.disabled = true;

            if (!centerId) {
                productSelect.innerHTML = '<option value="">-- @Localizer["Select center first"] --</option>';
                return;
            }

            try {
                const response = await fetch(`/Production/GetProducts?centerId=${centerId}`);
                const products = await response.json();

                productSelect.innerHTML = '<option value="">-- @Localizer["Select Product"] --</option>';
                products.forEach(p => {
                    productSelect.add(new Option(p.name, p.id));
                });
                productSelect.disabled = false;
            } catch (error) {
                productSelect.innerHTML = '<option value="">-- @Localizer["Error loading data"] --</option>';
            }
        });

        document.getElementById('transferForm').addEventListener('submit', function() {
            document.getElementById('productSelect').disabled = false;
        });
    </script>
}