@using Inventar.Web.ViewModels.Logistics
@using Microsoft.AspNetCore.Mvc.Localization
@model SalesPointReturnViewModel
@inject IViewLocalizer Localizer

<div class="container py-4">
    <h2 class="h3 mb-4 text-primary fw-bold">
        <i class="fas fa-undo-alt me-2"></i> @Localizer["Return Goods from Sales Point"]
    </h2>

    <form asp-action="ReturnActivity" method="post">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold text-dark">@Localizer["1. Destination Selection"]</h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-danger">@Localizer["From Sales Point (Source):"]</label>
                        <select asp-for="FromSalesPointId" class="form-select border-danger" id="salesPointSelect" asp-items="Model.SalesPoints">
                            <option value="">-- @Localizer["Select Sales Point"] --</option>
                        </select>
                        <span asp-validation-for="FromSalesPointId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-success">@Localizer["Where to return the goods?"]</label>
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check">
                                <input class="form-check-input dest-radio" type="radio" asp-for="DestinationType" value="Warehouse" id="destWarehouse" checked>
                                    <label class="form-check-label" for="destWarehouse">@Localizer["To Warehouse"]</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input dest-radio" type="radio" asp-for="DestinationType" value="ProductionCenter" id="destCenter">
                                        <label class="form-check-label" for="destCenter">@Localizer["To Center"]</label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold text-success">@Localizer["To (Destination):"]</label>
                        
                                <div id="warehouseDiv">
                                    <select class="form-select border-success target-select" id="warehouseSelect" name="ToDestinationId" asp-items="Model.Warehouses">
                                        <option value="">-- @Localizer["Select Warehouse"] --</option>
                                    </select>
                                </div>

                                <div id="centerDiv" style="display: none;">
                                    <select class="form-select border-success target-select" id="centerSelect" disabled asp-items="Model.ProductionCenters">
                                        <option value="">-- @Localizer["Select Center"] --</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0 fw-bold text-dark">@Localizer["2. Products to Return"]</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>@Localizer["Product"]</th>
                                    <th class="text-center" style="width: 200px;">@Localizer["Available in Sales Point"]</th>
                                    <th class="text-center" style="width: 200px;">@Localizer["Return Quantity"]</th>
                                </tr>
                            </thead>
                            <tbody id="productsTableBody">
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        @Localizer["Please select a Sales Point to load available products."]
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="text-end">
                    <a asp-controller="Production" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 me-2">Отказ</a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                        <i class="fas fa-check me-2"></i> @Localizer["Confirm Return"]
                    </button>
                </div>
            </form>
        </div>

        @section Scripts {
            <script>
                $(document).ready(function () {
            
                    $('.dest-radio').change(function () {
                        if ($('#destWarehouse').is(':checked')) {
                            $('#warehouseDiv').show();
                            $('#warehouseSelect').prop('disabled', false).attr('name', 'ToDestinationId');
                    
                            $('#centerDiv').hide();
                            $('#centerSelect').prop('disabled', true).removeAttr('name');
                        } else {
                            $('#centerDiv').show();
                            $('#centerSelect').prop('disabled', false).attr('name', 'ToDestinationId');
                    
                            $('#warehouseDiv').hide();
                            $('#warehouseSelect').prop('disabled', true).removeAttr('name');
                        }
                    });

                    $('#salesPointSelect').change(function () {
                        const salesPointId = $(this).val();
                        const $tableBody = $('#productsTableBody');

                        if (!salesPointId) {
                            $tableBody.html('<tr><td colspan="3" class="text-center py-4 text-muted">Моля, изберете обект.</td></tr>');
                            return;
                        }

                        $tableBody.html('<tr><td colspan="3" class="text-center py-4"><div class="spinner-border text-primary"></div></td></tr>');

                        $.getJSON('@Url.Action("GetSalesPointStocks", "Logistics")', { salesPointId: salesPointId }, function (data) {
                            $tableBody.empty();
                
                            if (!data || data.length === 0) {
                                $tableBody.html('<tr><td colspan="3" class="text-center py-4 text-muted">@Localizer["No stock available in this location."]</td></tr>');
                                return;
                            }

                            $.each(data, function (i, item) {
                                $tableBody.append(`
                                    <tr>
                                        <td>
                                            <input type="hidden" name="Products[${i}].ProductId" value="${item.productId}" />
                                            <input type="hidden" name="Products[${i}].ProductName" value="${item.productName}" />
                                            <span class="fw-bold">${item.productName}</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border fs-6">${item.availableInStock}</span>
                                            <input type="hidden" name="Products[${i}].AvailableQuantity" value="${item.availableInStock}" />
                                        </td>
                                        <td>
                                            <input type="number" name="Products[${i}].ReturnQuantity"
                                                   class="form-control text-center fw-bold text-primary border-primary"
                                                   min="0" max="${item.availableInStock}" step="1" value="0" />
                                        </td>
                                    </tr>
                                `);
                            });
                        }).fail(function() {
                            $tableBody.html('<tr><td colspan="3" class="text-center py-4 text-danger">@Localizer["Error loading data."]</td></tr>');
                        });
                    });
                });
            </script>
        }